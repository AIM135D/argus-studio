{
  "name": "argus-studio",
  "version": "0.1.0",
  "description": "ARGUS Studio — Edge Vision Engineering Workbench",
  "main": "out-electron/main.js",
  "author": "ARGUS Studio Contributors",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:web": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p app/electron/tsconfig.json --noEmit",
    "lint": "eslint app --ext .ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build:renderer": "vite build",
    "build:electron": "rm -rf out-electron && tsc -p app/electron/tsconfig.json",
    "build": "tsc --noEmit && tsc -p app/electron/tsconfig.json --noEmit && vite build && rm -rf out-electron && tsc -p app/electron/tsconfig.json",
    "dist:mac": "pnpm run build && bash scripts/package_macos.sh",
    "dist:dir": "pnpm run build && bash scripts/package_macos.sh --dir-only",
    "demo": "python scripts/generate_demo.py"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "studio.argus.desktop",
    "productName": "ARGUS Studio",
    "electronDist": "node_modules/electron/dist",
    "artifactName": "ARGUS-Studio-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-renderer/**/*",
      "out-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/argus-core",
        "to": "core",
        "filter": ["**/*"]
      },
      {
        "from": "demo_data",
        "to": "demo_data",
        "filter": ["**/*"]
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "docs/THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.developer-tools",
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "ARGUS Studio 需要读取你选择的视觉数据与实验文件。",
        "NSDownloadsFolderUsageDescription": "ARGUS Studio 需要读取或导出你明确选择的文件。"
      }
    },
    "dmg": {
      "title": "ARGUS Studio",
      "sign": false,
      "contents": [
        { "x": 140, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "packageManager": "pnpm@11.7.0"
}
